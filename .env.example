# ── LLM Providers ──────────────────────────────────
# Required by the GitHub Action (set as repo secrets) and local dev.
NEURALWATT_API_KEY=
DEEPSEEK_API_KEY=
# ── GitHub ─────────────────────────────────────────
# For local dev: create a classic PAT with 'repo' scope.
# In GitHub Actions: GITHUB_TOKEN is auto-provided — no setup needed.
GITHUB_TOKEN=
